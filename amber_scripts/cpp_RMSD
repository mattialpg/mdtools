module load amber/20_ompigw
export OMP_NUM_THREADS=1
ulimit -s unlimited

mpirun -np 6 cpptraj.MPI <<EOF
# CREATE AVG STRUCTURE
   parm com_gas.parm7
   trajin prod_FULL.mdcrd 1 10
   average avg_in.rst7
   average avg_in.pdb
   run
EOF

echo "Minimising..."

cat > min_avg <<EOF
   # Full minimization  
   &cntrl
   imin = 1,      ntb    = 0,       cut   = 10,    
   ncyc = 500,    maxcyc = 500,
   ntpr = 100,    ntwr   = 100,
   &end
EOF

mpirun -np 6 sander.MPI -O -i min_avg -o rmsd-avg.out -r rmsd-avg.rst7 -c avg_in.rst7 -ref avg_in.rst7 -p com_gas.parm7
ambpdb -p com_gas.parm7 -c rmsd-avg.rst7 > rmsd-avg.pdb
rm avg_in* min_avg mdinfo

mpirun -np 6 cpptraj.MPI<<EOF
   parm com_gas.parm7
   reference rmsd-avg.rst7 
   trajin prod_FULL.mdcrd 1 last 10

# CALCULATE RMSF
   rms reference
   atomicfluct out backbone.RMSF :8-611@C,N,CA byres

# CALCULATE RMSD CPT1A
   rmsd :10-262,278-390,398-580@C,N,CA reference mass out backbone_noloops.RMSD
# CALCULATE RMSD CPT1B
#   rmsd :10-120,141-179,188-452,462-525,541-590@C,N,CA reference mass out backbone_noloops.RMSD

#   trajout aligned_bck.mdcrd nobox # Use to check alignment #
   rmsd :10-590@C,N,CA reference mass out backbone.RMSD
   rmsd :10-590&!@H= reference mass out heavy.RMSD

# CALCULATE RMSD CPT1 + INHIBITOR
   rmsd :MOL<:4.0&!(:MOL)&@C,N,CA reference mass out pocket.RMSD
   rmsd :MOL&!@H= nofit reference mass out ligand.RMSD

# CALCULATE RMSD CPT1 + SUBSTRATES
   rmsd :COA&!@H= nofit reference mass out CoA.RMSD
   rmsd :CAR&!@H= nofit reference mass out Carnitine.RMSD

   run
EOF
